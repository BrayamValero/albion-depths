generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Player {
  id         String    @id
  name       String
  mmr        Int       @default(1000)
  kills      Int       @default(0)
  deaths     Int       @default(0)
  assists    Int       @default(0)
  streak     Int       @default(0)
  lastKillAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  killerKills      Kill[]              @relation("KillerKills")
  victimDeaths     Kill[]              @relation("VictimDeaths")
  h2hAsKiller      HeadToHead[]        @relation("H2HKiller")
  h2hAsVictim      HeadToHead[]        @relation("H2HVictim")
  eventParticipants EventParticipant[]
  weaponStats      WeaponStats[]
  seasonSnapshots  SeasonSnapshot[]

  @@index([mmr])
}

model Kill {
  id          Int    @id @default(autoincrement())
  eventId     String @unique
  killerId    String
  victimId    String
  mmrChange   Int
  killTime    DateTime
  fame        Int

  killerWeapon     String?
  victimWeapon     String?
  killerGuild      String?
  victimGuild      String?
  killerAlliance   String?
  victimAlliance   String?
  killerIp         Float?
  victimIp         Float?
  totalFame        Int?
  killArea         String?
  groupMemberCount Int?
  killerPartyMmr   Int?
  killerPartySize  Int?
  groupMembers     String? @db.Text
  battleId         String?
  location         String?
  lootSilverValue  Int?

  killer      Player            @relation("KillerKills", fields: [killerId], references: [id])
  victim      Player            @relation("VictimDeaths", fields: [victimId], references: [id])
  participants EventParticipant[]
  equipment   KillEquipment[]
  inventory   KillInventory[]

  @@index([killerId])
  @@index([victimId])
  @@index([killTime])
  @@index([killerWeapon])
  @@index([victimWeapon])
}

model HeadToHead {
  id         Int       @id @default(autoincrement())
  killerId   String
  victimId   String
  killCount  Int       @default(0)
  lastKillAt DateTime?

  killer Player @relation("H2HKiller", fields: [killerId], references: [id])
  victim Player @relation("H2HVictim", fields: [victimId], references: [id])

  @@unique([killerId, victimId])
  @@index([killerId])
  @@index([victimId])
}

model EventParticipant {
  id          Int      @id @default(autoincrement())
  killId      Int
  playerId    String
  role        String
  mmrChange   Int      @default(0)
  damageDone  Float    @default(0)
  healingDone Float    @default(0)
  ip          Float?

  kill   Kill   @relation(fields: [killId], references: [id])
  player Player @relation(fields: [playerId], references: [id])

  @@unique([killId, playerId])
  @@index([killId])
  @@index([playerId])
}

model KillEquipment {
  id       Int    @id @default(autoincrement())
  killId   Int
  owner    String
  slot     String
  itemType String
  quality  Int    @default(1)
  count    Int    @default(1)

  kill Kill @relation(fields: [killId], references: [id])

  @@index([killId])
}

model KillInventory {
  id       Int    @id @default(autoincrement())
  killId   Int
  itemType String
  quality  Int    @default(1)
  count    Int    @default(1)

  kill Kill @relation(fields: [killId], references: [id])

  @@index([itemType])
  @@index([killId])
}

model PriceCache {
  itemType  String
  quality   Int
  price     Int
  updatedAt DateTime @updatedAt

  @@id([itemType, quality])
}

model Season {
  id        Int      @id @default(autoincrement())
  number    Int      @unique
  startsAt  DateTime @default(now())
  endsAt    DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  snapshots SeasonSnapshot[]
}

model SeasonSnapshot {
  id           Int      @id @default(autoincrement())
  seasonId     Int
  seasonNumber Int
  playerId     String
  playerName   String
  mmr          Int
  tier         String
  rank         Int
  kills        Int
  deaths       Int
  assists      Int
  createdAt    DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id])
  season Season @relation(fields: [seasonId], references: [id])

  @@unique([seasonId, playerId])
  @@index([playerId])
  @@index([seasonId])
  @@index([seasonNumber])
}

model WeaponStats {
  id           Int    @id @default(autoincrement())
  playerId     String
  weaponKey    String
  weaponFamily String
  kills        Int    @default(0)
  deaths       Int    @default(0)

  player Player @relation(fields: [playerId], references: [id])

  @@unique([playerId, weaponKey])
  @@index([weaponFamily, deaths])
  @@index([weaponFamily, kills])
  @@index([weaponKey, kills])
}

model SyncLog {
  id          Int      @id @default(autoincrement())
  status      String
  message     String?
  killsSynced Int      @default(0)
  createdAt   DateTime @default(now())
}

model SyncState {
  id          Int      @id @default(autoincrement())
  lastEventId Int
  updatedAt   DateTime @updatedAt
}
